# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Server-side only. Never expose to frontend.

# ── Upstash Redis ─────────────────────────────────────────────
# Found in: Upstash Console → Database → REST API
UPSTASH_REDIS_URL=https://your-db.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token-here

# ── Reddit API (PRAW) ─────────────────────────────────────────
# Create an app at: https://www.reddit.com/prefs/apps  (type: script)
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=project-maximize-scraper/0.1

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── App ───────────────────────────────────────────────────────
ENVIRONMENT=development    # development | production
